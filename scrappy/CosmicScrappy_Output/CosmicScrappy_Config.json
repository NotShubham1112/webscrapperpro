{
  "configName": "Cosmic Scrappy Default Config",
  "version": "1.0.0",
  "settings": {
    "inputSources": [
      "web_search",
      "direct_url",
      "local_files"
    ],
    "extractionRules": {
      "timeout": 5000,
      "retryLimit": 3,
      "followRedirects": true
    },
    "outputFormats": [
      "docx",
      "xlsx",
      "pdf",
      "json",
      "txt"
    ],
    "retryLogic": {
      "strategy": "exponential_backoff",
      "maxDelay": 30000
    },
    "loggingSettings": {
      "level": "info",
      "path": "./logs/scrappy.log",
      "rotation": "daily"
    },
    "performanceOptions": {
      "concurrency": 5,
      "cacheEnabled": true
    }
  }
}