{
  "name": "scrappy",
  "version": "1.0.0",
  "description": "Scrappy — A fully agentic CLI chat assistant by Cosmic",
  "main": "dist/bin/scrappy.js",
  "bin": {
    "scrappy": "./dist/bin/scrappy.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/scrappy.js",
    "dev": "ts-node --esm src/bin/scrappy.ts",
    "dev:node": "ts-node src/bin/scrappy.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web-scraping",
    "cli",
    "agentic",
    "ai",
    "typescript",
    "cosmic"
  ],
  "author": "Cosmic",
  "license": "MIT",
  "dependencies": {
    "@types/fs-extra": "^11.0.4",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-spinners": "^2.9.0",
    "commander": "^14.0.3",
    "docx": "^8.5.0",
    "exceljs": "^4.4.0",
    "figlet": "^1.6.0",
    "inquirer": "^8.2.6",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1",
    "readline": "^1.3.0",
    "strip-ansi": "^7.2.0",
    "yahoo-finance2": "^3.14.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.5",
    "@types/inquirer": "^8.2.10",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.8.0",
    "@types/node-fetch": "^2.6.11",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.0"
  }
}
